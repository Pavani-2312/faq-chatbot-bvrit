# =============================================================================
# BVRIT FAQ Chatbot — .gitignore
# =============================================================================

# ---------------------------------------------------------------------------
# Secrets — never commit
# ---------------------------------------------------------------------------
.env
.env.local
.env.*
!.env.example

# ---------------------------------------------------------------------------
# Python
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/
dist/
build/
.eggs/

# ---------------------------------------------------------------------------
# Virtual environment
# ---------------------------------------------------------------------------
venv/
.venv/
env/
.env
ENV/

# ---------------------------------------------------------------------------
# Generated artifacts — rebuilt locally, not committed
# ---------------------------------------------------------------------------

# Vector index — rebuilt by: python3 src/ingest.py
chroma_db/


# Streamlit static symlink — recreated on setup
static/

# ---------------------------------------------------------------------------
# Evaluation outputs — generated by eval pipeline, optionally committed
# ---------------------------------------------------------------------------
# Comment these out if you want to commit eval results to the repo
tests/test_cases.json
tests/test_results.json
tests/ragas_scores.json
tests/evaluation_report.json

# ---------------------------------------------------------------------------
# Scraper raw output — large, not needed in repo
# ---------------------------------------------------------------------------
scaper/output/
scraped_data.json

# ---------------------------------------------------------------------------
# Source files that ARE committed (override any broad rules above)
# ---------------------------------------------------------------------------
# kb_formatted/ — curated knowledge base, MUST be committed
# .streamlit/   — Streamlit config (static serving), MUST be committed
# knowledge_base/ — source markdown files, MUST be committed

# ---------------------------------------------------------------------------
# OS / editor
# ---------------------------------------------------------------------------
.DS_Store
Thumbs.db
*.swp
*.swo
.idea/
.vscode/
*.code-workspace

# ---------------------------------------------------------------------------
# Logs & temp files
# ---------------------------------------------------------------------------
*.log
*.tmp
*.bak
